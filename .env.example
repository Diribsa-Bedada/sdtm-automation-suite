# ==============================================================
# SDTM Automation Suite — Environment Variables
# ==============================================================
# 🚨 IMPORTANT: Copy this file to .env and fill in your values.
#    NEVER commit the actual .env file to version control.
#
#    cp .env.example .env
# ==============================================================

# Google Gemini API Key (required for the AI agent pipeline)
# Obtain from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Raw data directory override (default: mock_data)
# RAW_DATA_DIR=mock_data

# Optional: Output directory override (default: output)
# OUTPUT_DIR=output
